        Property { name: "refinementCount";       type: "int";     isReadonly: false }

        // ── Signals ─────────────────────────────────────────────────────────
        Signal { name: "titleChanged" }
        Signal { name: "descriptionChanged" }
        Signal { name: "questionsJsonChanged" }
        Signal { name: "answersJsonChanged" }
        Signal { name: "remainingSecondsChanged" }
        Signal { name: "totalSecondsChanged" }
        Signal { name: "timerPausedChanged" }
        Signal { name: "formSubmittedChanged" }
