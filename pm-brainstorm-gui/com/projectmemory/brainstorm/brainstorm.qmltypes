        Property { name: "answersJson";           type: "QString"; isReadonly: false }
        Property { name: "remainingSeconds";      type: "int";     isReadonly: false }
        Property { name: "totalSeconds";          type: "int";     isReadonly: false }
        Property { name: "timerPaused";           type: "bool";    isReadonly: false }
